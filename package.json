{
  "name": "gqlsift",
  "version": "0.1.0",
  "description": "GraphQL schema diff and operation linter — breaking-change verdicts against real recorded queries, complexity scores and unused-field reports in one zero-dependency CLI.",
  "author": "JaydenCJ",
  "license": "MIT",
  "type": "module",
  "bin": {
    "gqlsift": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"tests/*.test.mjs\"",
    "smoke": "bash scripts/smoke.sh"
  },
  "keywords": [
    "graphql",
    "schema-diff",
    "breaking-changes",
    "linter",
    "query-complexity",
    "ci",
    "cli"
  ],
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaydenCJ/gqlsift.git"
  },
  "homepage": "https://github.com/JaydenCJ/gqlsift#readme",
  "bugs": {
    "url": "https://github.com/JaydenCJ/gqlsift/issues"
  }
}
